{
  "manifest_version": 3,
  "name": "Activity Monitor — Web Tracker",
  "version": "1.2",
  "description": "Sends the active tab's URL and title to your local Activity Monitor, and flags password/OTP fields so typed-text logging is suppressed there. Never transmits field values.",
  "permissions": ["tabs", "idle", "alarms", "storage"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "optional_host_permissions": ["http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "storage": {
    "managed_schema": "managed_schema.json"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Activity Monitor"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
