{
  "manifest_version": 3,
  "name": "Activity Monitor — Web Tracker",
  "version": "1.1",
  "description": "Sends the active tab's URL and title to your local Activity Monitor so the dashboard can show which websites you use. Configurable server + interval.",
  "permissions": ["tabs", "idle", "alarms", "storage"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "optional_host_permissions": ["http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "storage": {
    "managed_schema": "managed_schema.json"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Activity Monitor"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
